#!/usr/bin/env bash
# configure -- detect build environment and write config.mk
#
# Usage:
#   ./configure                  # auto-detect everything, GUI off by default
#   ./configure --with-qt        # enable GUI wallet build
#   ./configure --without-qt     # explicitly disable GUI wallet
#   ./configure --prefix=/usr    # set install prefix
#
# Modeled after Bitcoin Core's ./configure. Writes config.mk which the
# Makefile includes. Run once after cloning or when dependencies change.
set -euo pipefail

# --- Defaults ----------------------------------------------------------------
WITH_QT="auto"
WITH_WALLET=1
WITH_MINING=1
DEFAULT_NETWORK="testnet"
PREFIX="/usr/local"
MIN_NODE_MAJOR=20

# --- Parse arguments ---------------------------------------------------------
for arg in "$@"; do
    case "$arg" in
        --with-qt)       WITH_QT="yes" ;;
        --without-qt)    WITH_QT="no"  ;;
        --with-wallet)   WITH_WALLET=1 ;;
        --without-wallet) WITH_WALLET=0 ;;
        --with-mining)   WITH_MINING=1 ;;
        --without-mining) WITH_MINING=0 ;;
        --network=*)     DEFAULT_NETWORK="${arg#--network=}" ;;
        --prefix=*)      PREFIX="${arg#--prefix=}" ;;
        --help|-h)
            echo "Usage: ./configure [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --with-qt          Enable GUI wallet build (requires Wails, npm, Node >= $MIN_NODE_MAJOR, WebKit2GTK)"
            echo "  --without-qt       Disable GUI wallet build (default)"
            echo "  --with-wallet      Enable wallet support (default: on)"
            echo "  --without-wallet   Disable wallet support"
            echo "  --with-mining      Enable built-in miner (default: on)"
            echo "  --without-mining   Disable built-in miner"
            echo "  --network=NAME     Default network for QT wallet: testnet, regtest, mainnet (default: testnet)"
            echo "  --prefix=PATH      Installation prefix (default: /usr/local)"
            echo "  --help             Show this help"
            exit 0
            ;;
        *)
            echo "ERROR: unknown option: $arg" >&2
            echo "Run ./configure --help for usage." >&2
            exit 1
            ;;
    esac
done

# --- Helpers -----------------------------------------------------------------
ok()   { printf "  %-30s %s\n" "$1" "yes ($2)"; }
no()   { printf "  %-30s %s\n" "$1" "no"; }
fail() { printf "  %-30s %s\n" "$1" "MISSING"; echo "ERROR: $2" >&2; exit 1; }
warn() { printf "  %-30s %s\n" "$1" "no (optional)"; }

echo ""
echo "Configuring $(basename "$(pwd)")..."
echo ""
echo "Checking dependencies:"

# --- Required: Go ------------------------------------------------------------
GO=""
for candidate in go /usr/local/go/bin/go /snap/bin/go; do
    if command -v "$candidate" &>/dev/null; then
        GO="$(command -v "$candidate")"
        break
    fi
done
if [ -z "$GO" ]; then
    fail "go" "Go compiler not found. Install from https://go.dev/dl/"
fi
GO_VERSION="$($GO version | awk '{print $3}' | sed 's/go//')"
ok "go" "$GO_VERSION -- $GO"

# --- Required: bash ----------------------------------------------------------
ok "bash" "$BASH_VERSION"

# --- Required: pkg-config ----------------------------------------------------
if command -v pkg-config &>/dev/null; then
    ok "pkg-config" "$(pkg-config --version)"
else
    warn "pkg-config"
fi

# --- GOPATH/bin detection ----------------------------------------------------
GOPATH_BIN="$($GO env GOPATH)/bin"

# --- Optional: Wails CLI -----------------------------------------------------
WAILS=""
for candidate in "$GOPATH_BIN/wails" wails; do
    if [ -x "$candidate" ]; then
        WAILS="$(readlink -f "$candidate")"
        break
    elif command -v "$candidate" &>/dev/null 2>&1; then
        WAILS="$(command -v "$candidate")"
        break
    fi
done

WAILS_VERSION=""
if [ -n "$WAILS" ]; then
    WAILS_VERSION="$($WAILS version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")"
    ok "wails" "$WAILS_VERSION -- $WAILS"
else
    warn "wails"
fi

# --- Optional: Node.js + npm -------------------------------------------------
# Tailwind CSS v4 requires Node >= 20 for @tailwindcss/oxide native bindings.
# Resolve .nvmrc from this script (not $PWD). Source nvm with `set +u` — nvm.sh
# breaks under bash nounset. Sourcing nvm can drop a pre-set PATH from the parent
# shell if `nvm use` fails; we then prepend the newest nvm Node >= MIN_NODE_MAJOR.

CONFIGURE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NVMRC="$CONFIGURE_DIR/cmd/qt/frontend/.nvmrc"

NPM=""
NODE=""
NODE_VERSION=""
NODE_MAJOR=0
NVM_ACTIVATED=0

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

_prepend_nvm_node_path() {
    local dir ver maj
    if [ ! -d "$NVM_DIR/versions/node" ]; then
        return 1
    fi
    for dir in $(ls -1 "$NVM_DIR/versions/node" 2>/dev/null | sort -V | tac); do
        [ -x "$NVM_DIR/versions/node/$dir/bin/node" ] || continue
        ver="${dir#v}"
        maj="${ver%%.*}"
        if [ "${maj:-0}" -ge "$MIN_NODE_MAJOR" ] 2>/dev/null; then
            export PATH="$NVM_DIR/versions/node/$dir/bin:$PATH"
            NVM_ACTIVATED=1
            hash -r 2>/dev/null || true
            return 0
        fi
    done
    return 1
}

if [ -s "$NVM_DIR/nvm.sh" ]; then
    set +u
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh" --no-use
    set -u

    if [ -f "$NVMRC" ]; then
        if pushd "$(dirname "$NVMRC")" >/dev/null 2>&1; then
            if nvm use >/dev/null 2>&1; then
                NVM_ACTIVATED=1
                hash -r 2>/dev/null || true
            fi
            popd >/dev/null 2>&1 || true
        fi
    fi

    if [ "$NVM_ACTIVATED" != "1" ] && declare -F nvm >/dev/null 2>&1; then
        DESIRED_MAJOR="$MIN_NODE_MAJOR"
        if [ -f "$NVMRC" ]; then
            _raw="$(tr -d '[:space:]' < "$NVMRC" | sed 's/^v//')"
            DESIRED_MAJOR="${_raw%%.*}"
        fi

        if [ -n "$DESIRED_MAJOR" ] && nvm use "$DESIRED_MAJOR" >/dev/null 2>&1; then
            NVM_ACTIVATED=1
            hash -r 2>/dev/null || true
        else
            FALLBACK=""
            for v in $(nvm ls --no-colors 2>/dev/null | grep -oE 'v[0-9]+' | sed 's/v//' | sort -rn | uniq); do
                if [ "$v" -ge "$MIN_NODE_MAJOR" ]; then
                    FALLBACK="$v"
                    break
                fi
            done

            if [ -n "$FALLBACK" ] && nvm use "$FALLBACK" >/dev/null 2>&1; then
                NVM_ACTIVATED=1
                hash -r 2>/dev/null || true
            else
                echo ""
                echo "  Node.js >= $MIN_NODE_MAJOR is required for the GUI frontend (Tailwind v4)."
                echo "  nvm is available but no compatible Node version is installed."
                echo ""
                if [ -t 0 ]; then
                    read -rp "  Install Node $DESIRED_MAJOR via nvm now? [Y/n] " REPLY
                    REPLY="${REPLY:-Y}"
                else
                    REPLY="y"
                fi
                if [[ "$REPLY" =~ ^[Yy]$ ]]; then
                    echo "  Installing Node $DESIRED_MAJOR..."
                    nvm install "$DESIRED_MAJOR" >/dev/null 2>&1 || true
                    if nvm use "$DESIRED_MAJOR" >/dev/null 2>&1; then
                        NVM_ACTIVATED=1
                        hash -r 2>/dev/null || true
                    fi
                fi
            fi
        fi
    fi
fi

if command -v node &>/dev/null; then
    _probe="$(node --version | sed 's/^v//')"
    _maj="${_probe%%.*}"
    if [ "${_maj:-0}" -lt "$MIN_NODE_MAJOR" ] 2>/dev/null; then
        _prepend_nvm_node_path || true
    fi
fi

if command -v node &>/dev/null; then
    NODE="$(command -v node)"
    NODE_VERSION="$(node --version | sed 's/^v//')"
    NODE_MAJOR="${NODE_VERSION%%.*}"
fi

if command -v npm &>/dev/null; then
    NPM="$(command -v npm)"
    ok "npm" "$(npm --version) -- $NPM"
else
    warn "npm"
fi

if [ -n "$NODE" ]; then
    if [ "$NODE_MAJOR" -ge "$MIN_NODE_MAJOR" ]; then
        ok "node" "v$NODE_VERSION -- $NODE"
    else
        printf "  %-30s %s\n" "node" "v$NODE_VERSION (NEEDS >= $MIN_NODE_MAJOR)"
    fi
else
    warn "node"
fi

# --- Optional: WebKit2GTK (Linux only) ---------------------------------------
WEBKIT_TAG=""
WEBKIT_VERSION=""
if [ "$(uname)" = "Linux" ]; then
    if command -v pkg-config &>/dev/null; then
        if pkg-config --exists webkit2gtk-4.1 2>/dev/null; then
            WEBKIT_VERSION="$(pkg-config --modversion webkit2gtk-4.1)"
            WEBKIT_TAG="webkit2_41"
            ok "webkit2gtk" "4.1 ($WEBKIT_VERSION)"
        elif pkg-config --exists webkit2gtk-4.0 2>/dev/null; then
            WEBKIT_VERSION="$(pkg-config --modversion webkit2gtk-4.0)"
            WEBKIT_TAG=""
            ok "webkit2gtk" "4.0 ($WEBKIT_VERSION)"
        else
            warn "webkit2gtk"
        fi
    else
        warn "webkit2gtk (pkg-config missing)"
    fi

    if command -v pkg-config &>/dev/null && pkg-config --exists gtk+-3.0 2>/dev/null; then
        ok "gtk+-3.0" "$(pkg-config --modversion gtk+-3.0)"
    else
        warn "gtk+-3.0"
    fi
fi

# --- Resolve --with-qt -------------------------------------------------------
QT_ENABLED=0
QT_REASON=""
NODE_TOO_OLD=0

if [ -n "$NODE" ] && [ "$NODE_MAJOR" -lt "$MIN_NODE_MAJOR" ]; then
    NODE_TOO_OLD=1
fi

if [ "$WITH_QT" = "yes" ]; then
    MISSING=""
    [ -z "$WAILS" ] && MISSING="$MISSING wails"
    [ -z "$NPM" ] && MISSING="$MISSING npm"
    [ -z "$NODE" ] && MISSING="$MISSING node"
    [ "$NODE_TOO_OLD" = "1" ] && MISSING="$MISSING node>=$MIN_NODE_MAJOR"
    if [ "$(uname)" = "Linux" ] && [ -z "$WEBKIT_VERSION" ]; then
        MISSING="$MISSING webkit2gtk"
    fi
    if [ -n "$MISSING" ]; then
        echo ""
        echo "ERROR: --with-qt requested but missing dependencies:$MISSING" >&2
        echo "" >&2
        echo "Install them:" >&2
        echo "  Wails:     go install github.com/wailsapp/wails/v2/cmd/wails@latest" >&2
        echo "  Node.js:   curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash" >&2
        echo "             nvm install $MIN_NODE_MAJOR" >&2
        echo "  npm:       comes with Node.js (or: sudo apt install npm)" >&2
        echo "  WebKit:    sudo apt install libgtk-3-dev libwebkit2gtk-4.1-dev" >&2
        exit 1
    fi
    QT_ENABLED=1
    QT_REASON="requested via --with-qt"
elif [ "$WITH_QT" = "auto" ]; then
    if [ -n "$WAILS" ] && [ -n "$NPM" ] && [ -n "$NODE" ] && [ "$NODE_TOO_OLD" = "0" ]; then
        if [ "$(uname)" != "Linux" ] || [ -n "$WEBKIT_VERSION" ]; then
            QT_ENABLED=1
            QT_REASON="auto-detected"
        fi
    fi
    if [ "$QT_ENABLED" = "0" ]; then
        QT_REASON="dependencies not found (use --with-qt to see what's missing)"
    fi
else
    QT_REASON="disabled via --without-qt"
fi

# --- Extract coinparams ------------------------------------------------------
echo ""
echo "Extracting coin parameters..."
bash scripts/coinparams.sh > coinparams.mk
echo "  Source: internal/coinparams/coinparams.go"

eval "$(bash scripts/coinparams.sh --env)"
echo "  Coin:   $COIN_NAME ($COIN_NAME_LOWER)"
echo "  Daemon: $DAEMON_NAME"
echo "  CLI:    $CLI_NAME"
echo "  GUI:    $GUI_NAME"

# --- Write config.mk ---------------------------------------------------------
CONFIG_MK="config.mk"
cat > "$CONFIG_MK" <<EOF
# Generated by ./configure -- do not edit.
# Re-run ./configure to regenerate.

# Tool paths
GO := $GO
WAILS := $WAILS
NPM := $NPM
NODE := $NODE

# Build flags
WITH_QT := $QT_ENABLED
WITH_WALLET := $WITH_WALLET
WITH_MINING := $WITH_MINING
DEFAULT_NETWORK := $DEFAULT_NETWORK

# WebKit build tag (webkit2_41 for 4.1, empty for 4.0)
WEBKIT_TAG := $WEBKIT_TAG

# Install prefix
PREFIX := $PREFIX
EOF

# If nvm was activated, write a shell snippet the Makefile can source.
if [ "$NVM_ACTIVATED" = "1" ]; then
    cat >> "$CONFIG_MK" <<EOF

# nvm activation (source this in shell steps that need node/npm)
NVM_DIR := $NVM_DIR
NVM_NODE_VERSION := $NODE_MAJOR
EOF
fi

# --- Summary ------------------------------------------------------------------
echo ""
echo "Build configuration:"
echo "  GUI wallet (qt):       $([ "$QT_ENABLED" = "1" ] && echo "YES" || echo "no") ($QT_REASON)"
echo "  Wallet support:        $([ "$WITH_WALLET" = "1" ] && echo "YES" || echo "no")"
echo "  Mining support:        $([ "$WITH_MINING" = "1" ] && echo "YES" || echo "no")"
if [ "$QT_ENABLED" = "1" ] && [ -n "$WEBKIT_TAG" ]; then
    echo "  WebKit build tag:      $WEBKIT_TAG"
fi
echo "  Default network:       $DEFAULT_NETWORK"
echo "  Install prefix:        $PREFIX"
echo ""
echo "Configuration written to $CONFIG_MK"
echo ""
if [ "$QT_ENABLED" = "1" ]; then
    echo "Run:  make build        # builds $DAEMON_NAME, $CLI_NAME, $GUI_NAME"
else
    echo "Run:  make build        # builds $DAEMON_NAME, $CLI_NAME"
    echo "      ./configure --with-qt && make build   # to also build $GUI_NAME"
fi
echo ""
